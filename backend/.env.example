# Environment Configuration for Localix Backend

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:///./localix.db

# MySQL (Production - uncomment and configure)
# DATABASE_URL=mysql+pymysql://root:password@localhost/localix

# PostgreSQL (Production - uncomment and configure)
# DATABASE_URL=postgresql://user:password@localhost/localix

# Ollama AI Configuration
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Scraper Configuration
SCRAPER_INTERVAL_HOURS=6
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
